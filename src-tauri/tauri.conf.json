{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mihomo Server Manager",
  "version": "0.1.12",
  "identifier": "com.local.mihomomanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mihomo Server Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Local",
    "category": "DeveloperTool",
    "shortDescription": "Local SSH manager for mihomo servers.",
    "longDescription": "A local desktop application for installing, configuring, and operating mihomo on headless Linux servers through SSH.",
    "icon": [
      "icons/icon.png",
      "icons/128x128.png",
      "icons/32x32.png",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "startMenuFolder": "Mihomo Server Manager"
      }
    }
  }
}
